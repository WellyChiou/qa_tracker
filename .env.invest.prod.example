# =========================
# Invest-only deployment env
# Copy to .env.invest.prod and replace values before remote production use.
# =========================

# Runtime timezone
TZ=Asia/Taipei

# Nginx exposed port
INVEST_NGINX_PORT=80

# MySQL bootstrap
INVEST_DB_ROOT_PASSWORD=replace_me_root_password
INVEST_DB_NAME=invest
INVEST_DB_APP_USER=appuser
INVEST_DB_APP_PASSWORD=replace_me_app_password

# Backend datasource
INVEST_JDBC_URL=jdbc:mysql://mysql:3306/invest?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=utf8&useUnicode=true
INVEST_JDBC_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# JWT
INVEST_JWT_SECRET=replace_me_base64_secret
INVEST_JWT_ACCESS_TOKEN_EXPIRATION=3600000
INVEST_JWT_REFRESH_TOKEN_ENABLED=true
INVEST_JWT_REFRESH_TOKEN_EXPIRATION=604800000
# Comma-separated whitelist for browser Origin header
INVEST_CORS_ALLOWED_ORIGIN_PATTERNS=https://power-light-church.duckdns.org,https://38.54.89.136,http://localhost,http://127.0.0.1

# Step 3 scheduler (daily report)
INVEST_SCHEDULER_DAILY_REPORT_ENABLED=false
INVEST_SCHEDULER_DAILY_REPORT_CRON=0 10 18 * * *
INVEST_SCHEDULER_DAILY_REPORT_ZONE=Asia/Taipei

# Step 4 scheduler (alert polling)
INVEST_SCHEDULER_ALERT_POLLING_ENABLED=false
INVEST_SCHEDULER_ALERT_POLLING_FIXED_DELAY_MS=120000
INVEST_SCHEDULER_ALERT_POLLING_INITIAL_DELAY_MS=30000

# Step 4 alert rule params
INVEST_ALERT_ABNORMAL_DROP_THRESHOLD_PERCENT=2.0
INVEST_ALERT_ABNORMAL_DROP_WINDOW_MINUTES=10
INVEST_ALERT_ABNORMAL_DROP_COOLDOWN_MINUTES=10

# V2 Phase 1-1 price provider
INVEST_PRICE_PROVIDER_TIMEOUT_MS=8000
INVEST_PRICE_PROVIDER_USER_AGENT=InvestAdmin/1.0
INVEST_PRICE_PROVIDER_TW_TWSE_URL=https://openapi.twse.com.tw/v1/exchangeReport/STOCK_DAY_ALL
INVEST_PRICE_PROVIDER_TW_TPEX_URL=https://www.tpex.org.tw/openapi/v1/tpex_mainboard_quotes
INVEST_PRICE_PROVIDER_US_STOOQ_URL_TEMPLATE=https://stooq.com/q/l/?s=%s&i=d

# V2 Phase 1-2 scheduler / retry / data quality
INVEST_SCHEDULER_PRICE_UPDATE_ENABLED=false
INVEST_SCHEDULER_PRICE_UPDATE_TW_CRON=0 30 15 * * MON-FRI
INVEST_SCHEDULER_PRICE_UPDATE_TW_ZONE=Asia/Taipei
INVEST_SCHEDULER_PRICE_UPDATE_US_CRON=0 30 6 * * TUE-SAT
INVEST_SCHEDULER_PRICE_UPDATE_US_ZONE=Asia/Taipei
INVEST_PRICE_UPDATE_RETRY_MAX_ATTEMPTS=2
INVEST_PRICE_UPDATE_RETRY_DELAY_MS=300
INVEST_PRICE_UPDATE_DATA_QUALITY_STALE_CALENDAR_DAYS=3
